# Weather MCP App - Environment Configuration

# API Configuration
# The MCP app is prepared to work with any weather API provider
# Uncomment and configure based on your chosen API provider

# ===== OPENWEATHERMAP API =====
# Provider: Open-Meteo (Free weather data, no API key required)
# Docs: https://open-meteo.com/
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1
WEATHER_API_PROVIDER=meteo
WEATHER_API_KEY=  # Not required for Open-Meteo free tier

# ===== ALTERNATIVE: OPENWEATHERMAP.ORG =====
# Provider: OpenWeatherMap
# Docs: https://openweathermap.org/api
# WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
# WEATHER_API_PROVIDER=openweathermap
# WEATHER_API_KEY=your_openweathermap_api_key

# ===== ALTERNATIVE: WEATHERAPI.COM =====
# Provider: WeatherAPI
# Docs: https://www.weatherapi.com/
# WEATHER_API_BASE_URL=https://api.weatherapi.com/v1
# WEATHER_API_PROVIDER=weatherapi
# WEATHER_API_KEY=your_weatherapi_key

# Server Configuration
PORT=3002

# Notes:
# - The weather service is designed to be API-agnostic
# - Update src/services/weatherService.ts to add provider-specific normalization logic
# - Each provider has different response formats, update normalizeWeatherData() accordingly
